# Backend Environment Variables
# Copy this to .env and fill in your actual values

# Database
DATABASE_TYPE=sqlite
# DATABASE_TYPE=postgres (for production)

# API Configuration
PORT=3000
NODE_ENV=development

# ─── JWT Secret (OBLIGATORIO en producción) ────────────────────────────────
# Genera un valor seguro con: require('crypto').randomBytes(32).toString('hex')
JWT_SECRET=your_jwt_secret_here_change_this

# Groq API (LLM rápido)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API (LLM con mayor límite)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS
CORS_ORIGIN=http://localhost:19000

# Optional: Backend URL (for CORS policies)
BACKEND_URL=http://localhost:3000

# ─── Uploadthing (Almacenamiento de archivos) ────────────────────────────────
# Obtener desde: https://uploadthing.com → Tu App → API Keys
UPLOADTHING_TOKEN=your_uploadthing_token_here

# ─── Resend (Servicio de Email para recuperación de contraseña) ───────────────
# Obtener desde: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Dominio verificado en Resend (o usar onboarding@resend.dev para pruebas)
RESEND_FROM_EMAIL=Threshold <noreply@tudominio.com>
