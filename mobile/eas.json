{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://threshold-backend-cn82.onrender.com/api",
        "EXPO_PUBLIC_GROQ_API_KEY": "@env GROQ_API_KEY"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://threshold-backend-cn82.onrender.com/api",
        "EXPO_PUBLIC_GROQ_API_KEY": "@env GROQ_API_KEY"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://threshold-backend-cn82.onrender.com/api",
        "EXPO_PUBLIC_GROQ_API_KEY": "@env GROQ_API_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
