# Copia este archivo a .env.local y coloca la IP LAN de tu PC.
# NOTA: Las API keys (como GROQ_API_KEY y GEMINI_API_KEY) se manejan en el backend, no aquí.

NODE_ENV=development
EXPO_PUBLIC_API_HOST=192.168.1.X
EXPO_PUBLIC_API_URL=https://threshold-backend-cn82.onrender.com/api

# LLM Selection (defecto: groq)
EXPO_PUBLIC_PREFERRED_LLM_PROVIDER=groq

# ─── Uploadthing ───────────────────────────────────────────────────────────────
# No se necesitan claves aquí. Las subidas de archivos (fotos, audios, documentos)
# pasan por el backend de Threshold, que tiene el UPLOADTHING_TOKEN en su .env.
