{
  "expo": {
    "name": "Threshold",
    "slug": "threshold",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#0E0E18",
    "icon": "./src/images/ThresholdIcons/android/playstore/appicononline.png",
    "scheme": "threshold",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "vnd.youtube",
          "youtube"
        ]
      }
    },
    "android": {
      "package": "com.oponobono.threshold",
      "icon": "./src/images/ThresholdIcons/android/playstore/appicononline.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_DOCUMENTS",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "www.youtube.com" },
            { "scheme": "https", "host": "youtu.be" },
            { "scheme": "vnd.youtube" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./src/images/ThresholdIcons/web/favicon-32x32.png"
    },
    "plugins": [
      "expo-router",
      "expo-background-fetch",
      "expo-camera",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E0E18",
          "dark": {
            "backgroundColor": "#0E0E18"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Threshold necesita acceso para escanear tus apuntes con precisión."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7cf9853-fa63-4fa1-9beb-e7da96cd4066"
      }
    }
  }
}
