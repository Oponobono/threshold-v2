{
  "expo": {
    "name": "Threshold",
    "slug": "threshold",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/images/ThresholdIcons/android/playstore/appicononline.png",
    "scheme": "threshold",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.oponobono.threshold",
      "icon": "./src/images/ThresholdIcons/android/playstore/appicononline.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_DOCUMENTS",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./src/images/ThresholdIcons/web/favicon-32x32.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/images/logo_threshold.png",
          "imageWidth": 600,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Threshold necesita acceso para escanear tus apuntes con precisión."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7cf9853-fa63-4fa1-9beb-e7da96cd4066"
      }
    }
  }
}
